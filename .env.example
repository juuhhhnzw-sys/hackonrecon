# =============================================================================
# HackOn Recon — environment template (copy to .env if you use a loader)
# =============================================================================
#
# Backend API (optional). Comma-separated extra CORS origins for your
# deployed frontend (e.g. Vercel / Netlify). Localhost is already allowed
# via defaults + regex in code.
#
# HACKON_CORS_ORIGINS=https://meu-app.vercel.app,https://www.meudominio.com
#
# -----------------------------------------------------------------------------
# Frontend: copy frontend/.env.example → frontend/.env
# -----------------------------------------------------------------------------
# VITE_API_BASE_URL=http://127.0.0.1:8000
#
# Nothing else is required for local development.
